#!/usr/bin/env bash
# CI/CD Configuration for torchtitan
# Source this file from other CI scripts: source "$(dirname "$0")/config.env"

# ============================================================================
# Paths
# ============================================================================
PROJECT_ROOT="/home/phuc/workspace/moe/small_prs/pr009_slurm_cicd"
TORCHTITAN_DIR="${PROJECT_ROOT}/torchtitan"
VENV_DIR="${PROJECT_ROOT}/.venv"
CI_DIR="${PROJECT_ROOT}/ci"
CI_LOG_DIR="${CI_DIR}/logs"
CI_STATE_DIR="${CI_DIR}/state"
LAST_TESTED_SHA_FILE="${CI_STATE_DIR}/.last_tested_sha"

# ============================================================================
# Git
# ============================================================================
GIT_BRANCH="dev-updated-again"
GIT_REMOTE="origin"

# ============================================================================
# Slurm (single node, 8 GPUs)
# ============================================================================
SLURM_PARTITION="batch"
SLURM_NODES=1
SLURM_GPUS_PER_NODE=8
SLURM_CPUS_PER_TASK=48
SLURM_TIME_LIMIT="01:00:00"
SLURM_JOB_NAME="ci-torchtitan-tests"
MIN_IDLE_NODES=1

# ============================================================================
# Timeouts (per phase)
# ============================================================================
TIMEOUT_UNIT_TESTS="5m"
TIMEOUT_DISTRIBUTED_TESTS="10m"
TIMEOUT_INTEGRATION_TESTS="30m"

# ============================================================================
# Discord Notifications
# ============================================================================
# Set this to your Discord webhook URL, or leave empty to log-only
DISCORD_WEBHOOK_URL="${DISCORD_WEBHOOK_URL:-}"
# Optional: Discord user/role ID to mention on failure (e.g., "<@123456789>")
DISCORD_MENTION_ON_FAIL="${DISCORD_MENTION_ON_FAIL:-}"

# ============================================================================
# Log Retention
# ============================================================================
LOG_RETENTION_DAYS=30

# ============================================================================
# Unit Test Files (plain pytest, no torchrun needed)
# ============================================================================
UNIT_TEST_FILES=(
    tests/unit_tests/test_activation_checkpoint.py
    tests/unit_tests/test_checkpoint.py
    tests/unit_tests/test_dataset_checkpointing.py
    tests/unit_tests/test_dataset_flux.py
    tests/unit_tests/test_download_hf_assets.py
    tests/unit_tests/test_job_config.py
    tests/unit_tests/test_lr_scheduler.py
    tests/unit_tests/test_model_converter.py
    tests/unit_tests/test_permute_indices_kernel.py
    tests/unit_tests/test_set_determinism.py
    tests/unit_tests/test_tokenizer.py
    tests/unit_tests/test_train_spec.py
)

# ============================================================================
# Distributed test (require torchrun, single node)
# ============================================================================
# Phase 2a: DeepEP token dispatcher (8 GPU)
DIST_TEST_DEEPEP="tests.unit_tests.deepep.test_primus_turbo_flex_token_dispatcher"
DIST_TEST_DEEPEP_NGPU=8

# Rendezvous port for distributed tests
RDZV_PORT_2A=29501

# ============================================================================
# DeepEP / NVSHMEM Runtime (required for distributed tests)
# ============================================================================
TORCH_LIB_PATH="${VENV_DIR}/lib/python3.10/site-packages/torch/lib"
NVSHMEM_LIB_PATH="${VENV_DIR}/lib/python3.10/site-packages/nvidia/nvshmem/lib"
export LD_LIBRARY_PATH="${TORCH_LIB_PATH}:${NVSHMEM_LIB_PATH}:${LD_LIBRARY_PATH:-}"
export NVSHMEM_DIR="${VENV_DIR}/lib/python3.10/site-packages/nvidia/nvshmem"

# ============================================================================
# NCCL / CUDA Environment (matches existing slurm scripts)
# ============================================================================
export CUDA_DEVICE_MAX_CONNECTIONS=1
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
export NCCL_TIMEOUT=1800000
export NCCL_DEBUG=WARN
export NCCL_SOCKET_IFNAME=bond0
export OMP_NUM_THREADS=4
